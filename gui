function RuneUI:CreateTabBox(parent, tabNames, pageData)
    local currentTab = 1

    local holder = Create("Frame", {
        Parent = parent,
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
    })

    local body = Create("Frame", {
        Parent = holder,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = Theme.Surface,
        BorderSizePixel = 0,
        ClipsDescendants = true,
    })
    Create("UICorner", {
        CornerRadius = UDim.new(0, 12),
        Parent = body,
    })
    local bodyStroke = Stroke(body, Theme.Border)
    Padding(body, 10, 10, 10, 10)

    local tabBar = Create("Frame", {
        Parent = body,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(1, 0, 0, 28),
        BackgroundTransparency = 1,
    })
    ListLayout(tabBar, 6, true)

    local divider = Create("Frame", {
        Parent = body,
        Position = UDim2.new(0, 0, 0, 34),
        Size = UDim2.new(1, 0, 0, 1),
        BackgroundColor3 = Theme.BorderSoft,
        BorderSizePixel = 0,
    })

    local contentWrap = Create("Frame", {
        Parent = body,
        Position = UDim2.new(0, 0, 0, 44),
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
    })

    local tabs = {}

    local function selectTab(index)
        if self.OpenDropdowns then
            for _, close in ipairs(self.OpenDropdowns) do
                close()
            end
        end

        currentTab = index

        for i, data in ipairs(tabs) do
            local active = i == index
            data.Content.Visible = active
            data.Button.BackgroundColor3 = active and Theme.AccentDark or Theme.Surface2
            data.Button.TextColor3 = active and Theme.Text or Theme.SubText
            data.Underline.Visible = active
        end
    end

    for i, name in ipairs(tabNames or {"Tab 1", "Tab 2"}) do
        local btn = Create("TextButton", {
            Parent = tabBar,
            Size = UDim2.new(0, 90, 1, 0),
            BackgroundColor3 = Theme.Surface2,
            BorderSizePixel = 0,
            Text = tostring(name),
            Font = Enum.Font.Code,
            TextColor3 = Theme.SubText,
            TextSize = 14,
            AutoButtonColor = false,
        })
        Round(btn, 6)
        local st = Stroke(btn, Theme.BorderSoft)

        local underline = Create("Frame", {
            Parent = btn,
            AnchorPoint = Vector2.new(0.5, 1),
            Position = UDim2.new(0.5, 0, 1, 0),
            Size = UDim2.new(1, 0, 0, 2),
            BackgroundColor3 = Theme.Accent,
            BorderSizePixel = 0,
            Visible = false,
        })

        local content = Create("Frame", {
            Parent = contentWrap,
            Size = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            Visible = false,
        })
        ListLayout(content, 10)

        self:RegisterThemeObject(btn, {BackgroundColor3 = "Surface2", TextColor3 = "SubText"})
        self:RegisterThemeObject(st, {Color = "BorderSoft"})
        self:RegisterThemeObject(underline, {BackgroundColor3 = "Accent"})

        tabs[i] = {
            Button = btn,
            Underline = underline,
            Content = content,
            Name = tostring(name),
            Select = function()
                selectTab(i)
            end,
        }

        btn.MouseButton1Click:Connect(function()
            selectTab(i)
        end)
    end

    if #tabs > 0 then
        selectTab(1)
    end

    self:RegisterThemeObject(body, {BackgroundColor3 = "Surface"})
    self:RegisterThemeObject(bodyStroke, {Color = "Border"})
    self:RegisterThemeObject(divider, {BackgroundColor3 = "BorderSoft"})

    local tabBoxData = {
        Holder = holder,
        Tabs = tabs,
        Body = body,
        ContentWrap = contentWrap,
        Refresh = function()
            selectTab(currentTab)
        end,
    }

    if pageData then
        pageData.TabBoxes = pageData.TabBoxes or {}
        table.insert(pageData.TabBoxes, tabBoxData)
    end

    return holder, tabs
end

