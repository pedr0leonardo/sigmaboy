function SaveManager:Init(ui)
    self.UI = ui
    self.Folder = "RuneHubConfigs"
    self.AutoLoadFile = self.Folder .. "/autoload.txt"

    if makefolder and not isfolder(self.Folder) then
        makefolder(self.Folder)
    end
end

function SaveManager:GetConfigPath(name)
    return self.Folder .. "/" .. tostring(name) .. ".json"
end

function SaveManager:ListConfigs()
    if not listfiles or not isfolder or not isfolder(self.Folder) then
        return {}
    end

    local out = {}
    for _, path in ipairs(listfiles(self.Folder)) do
        local name = path:match("([^\\/]+)$")
        
        if name and name ~= "autoload.txt" then -- 👈 FILTER IT HERE
            name = name:gsub("%.json$", "")
            table.insert(out, name)
        end
    end

    table.sort(out, function(a, b)
        return a:lower() < b:lower()
    end)

    return out
end
function SaveManager:Save(name)
    if not writefile then
        return false, "writefile unavailable"
    end
    if not name or name == "" then
        return false, "missing config name"
    end

    local ok, encoded = pcall(function()
        return HttpService:JSONEncode(Flags)
    end)
    if not ok then
        return false, "encode failed"
    end

    writefile(self:GetConfigPath(name), encoded)
    return true
end

function SaveManager:Load(name)
    if not readfile or not isfile then
        return false, "readfile unavailable"
    end

    local path = self:GetConfigPath(name)
    if not isfile(path) then
        return false, "config missing"
    end

    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    if not ok or type(decoded) ~= "table" then
        return false, "decode failed"
    end

    if self.UI then
        self.UI:ApplyFlags(decoded)
    else
        for k, v in pairs(decoded) do
            Flags[k] = v
        end
    end

    return true, decoded
end

function SaveManager:Delete(name)
    if not delfile or not isfile then
        return false, "delfile unavailable"
    end

    local path = self:GetConfigPath(name)
    if not isfile(path) then
        return false, "config missing"
    end

    delfile(path)
    return true
end

function SaveManager:SetAutoload(name)
    if not writefile then
        return false, "writefile unavailable"
    end
    writefile(self.AutoLoadFile, tostring(name or ""))
    return true
end

function SaveManager:GetAutoload()
    if not readfile or not isfile or not isfile(self.AutoLoadFile) then
        return nil
    end

    local ok, content = pcall(function()
        return readfile(self.AutoLoadFile)
    end)
    if ok and content ~= "" then
        return content
    end

    return nil
end

function RuneUI.new()
    return BuildWindow()
end

