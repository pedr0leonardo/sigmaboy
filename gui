local function vibrateCircle()
    local startPos = toggleCircle.Position
    local startRot = toggleIcon.Rotation

    local shakeOffsets = {
        UDim2.new(startPos.X.Scale, startPos.X.Offset - 3, startPos.Y.Scale, startPos.Y.Offset),
        UDim2.new(startPos.X.Scale, startPos.X.Offset + 3, startPos.Y.Scale, startPos.Y.Offset),
