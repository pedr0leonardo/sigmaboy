function RuneUI:CreateMultiDropdown(parent, title, options, default, callback, flag)
    flag = flag or title
    options = options or {}
    default = default or {}

    local selectedMap = {}
    for _, v in ipairs(default) do
        selectedMap[tostring(v)] = true
    end

    local expanded = false
    self.OpenDropdowns = self.OpenDropdowns or {}

    local holder = Create("Frame", {
        Parent = parent,
        Size = UDim2.new(1, 0, 0, 56),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
    })

    local label = Create("TextLabel", {
        Parent = holder,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 16),
        Font = Enum.Font.Code,
        Text = title,
        TextColor3 = Theme.Text,
        TextSize = 15,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local main = Create("TextButton", {
        Parent = holder,
        Position = UDim2.new(0, 0, 0, 22),
        Size = UDim2.new(1, 0, 0, 30),
        BackgroundColor3 = Theme.Surface2,
        BorderSizePixel = 0,
        Text = "",
        AutoButtonColor = false,
    })
    Round(main, 8)
    local mainStroke = Stroke(main, Theme.Border)

    local valueLabel = Create("TextLabel", {
        Parent = main,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 10, 0, 0),
        Size = UDim2.new(1, -30, 1, 0),
        Font = Enum.Font.Code,
        Text = "---",
        TextColor3 = Theme.Text,
        TextSize = 15,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
    })

    local arrow = Create("ImageLabel", {
        Parent = main,
        BackgroundTransparency = 1,
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -10, 0.5, 0),
        Size = UDim2.new(0, 14, 0, 14),
        Image = Assets.Chevron,
        ImageColor3 = Theme.SubText,
    })

    local listHolder = Create("ScrollingFrame", {
        Parent = self.ScreenGui,
        Position = UDim2.new(0, 0, 0, 56),
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = Theme.Surface,
        BorderSizePixel = 0,
        Visible = false,
        ZIndex = 4,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        ScrollBarThickness = 4,
        ScrollingDirection = Enum.ScrollingDirection.Y,
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
    })
    Round(listHolder, 8)
    local listStroke = Stroke(listHolder, Theme.Border)
    Padding(listHolder, 6, 6, 6, 6)
    ListLayout(listHolder, 4)
    listHolder.ClipsDescendants = true

    local function getSelectedList()
        local out = {}
        for _, option in ipairs(options) do
            option = tostring(option)
            if selectedMap[option] then
                table.insert(out, option)
            end
        end
        return out
    end

    local function updateLabel()
        local picked = getSelectedList()
        if #picked == 0 then
            valueLabel.Text = "---"
        elseif #picked <= 2 then
            valueLabel.Text = table.concat(picked, ", ")
        else
            valueLabel.Text = tostring(#picked) .. " selected"
        end
        Flags[flag] = picked
        if callback then
            callback(picked)
        end
    end

    local function closeDropdown()
        expanded = false
        listHolder.Visible = false
        TweenService:Create(arrow, TweenInfo.new(0.15), {
            Rotation = 0
        }):Play()
    end
    table.insert(self.OpenDropdowns, closeDropdown)

    local function rebuildOptions(newOptions)
        options = newOptions or options or {}

        for _, child in ipairs(listHolder:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end

        for _, option in ipairs(options) do
            option = tostring(option)

            local opt = Create("TextButton", {
                Parent = listHolder,
                Size = UDim2.new(1, 0, 0, 26),
                BackgroundColor3 = Theme.Surface2,
                BorderSizePixel = 0,
                Text = "",
                AutoButtonColor = false,
                ZIndex = 5,
            })
            Round(opt, 6)
            local optStroke = Stroke(opt, Theme.BorderSoft)

            local check = Create("Frame", {
                Parent = opt,
                AnchorPoint = Vector2.new(0, 0.5),
                Position = UDim2.new(0, 8, 0.5, 0),
                Size = UDim2.new(0, 14, 0, 14),
                BackgroundColor3 = selectedMap[option] and Theme.Accent or Theme.Background2,
                BorderSizePixel = 0,
                ZIndex = 6,
            })
            Round(check, 999)
            local checkStroke = Stroke(check, selectedMap[option] and Theme.Accent or Theme.BorderSoft)

            local optLabel = Create("TextLabel", {
                Parent = opt,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 30, 0, 0),
                Size = UDim2.new(1, -38, 1, 0),
                Font = Enum.Font.Code,
                Text = option,
                TextColor3 = Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 6,
            })

            AddHover(opt, {BackgroundColor3 = Color3.fromRGB(31, 31, 38)}, {BackgroundColor3 = Theme.Surface2})

            self:RegisterThemeObject(opt, {BackgroundColor3 = "Surface2"})
            self:RegisterThemeObject(optStroke, {Color = "BorderSoft"})
            self:RegisterThemeObject(optLabel, {TextColor3 = "Text"})

            opt.MouseButton1Click:Connect(function()
                selectedMap[option] = not selectedMap[option]

                TweenService:Create(check, TweenInfo.new(0.12), {
                    BackgroundColor3 = selectedMap[option] and Theme.Accent or Theme.Background2
                }):Play()

                TweenService:Create(checkStroke, TweenInfo.new(0.12), {
                    Color = selectedMap[option] and Theme.Accent or Theme.BorderSoft
                }):Play()

                updateLabel()
            end)
        end
    end

    rebuildOptions(options)
    updateLabel()

    main.MouseButton1Click:Connect(function()
        local wasExpanded = expanded

        if self.OpenDropdowns then
            for _, close in ipairs(self.OpenDropdowns) do
                close()
            end
        end

        expanded = not wasExpanded
        listHolder.Visible = expanded

        if expanded then
            local absPos = main.AbsolutePosition
            local absSize = main.AbsoluteSize
            local maxHeight = 150

            listHolder.Position = UDim2.new(
                0, absPos.X,
                0, absPos.Y + absSize.Y + 64
            )

            listHolder.Size = UDim2.new(
                0, absSize.X,
                0, maxHeight
            )
        end

        TweenService:Create(arrow, TweenInfo.new(0.15), {
            Rotation = expanded and 180 or 0
        }):Play()
    end)

    self:RegisterThemeObject(label, {TextColor3 = "Text"})
    self:RegisterThemeObject(main, {BackgroundColor3 = "Surface2"})
    self:RegisterThemeObject(mainStroke, {Color = "Border"})
    self:RegisterThemeObject(valueLabel, {TextColor3 = "Text"})
    self:RegisterThemeObject(arrow, {ImageColor3 = "SubText"})
    self:RegisterThemeObject(listHolder, {BackgroundColor3 = "Surface"})
    self:RegisterThemeObject(listStroke, {Color = "Border"})

    self.FlagObjects[flag] = {
        Type = "MultiDropdown",
        Set = function(values)
            selectedMap = {}
            for _, v in ipairs(values or {}) do
                selectedMap[tostring(v)] = true
            end
            rebuildOptions(options)
            updateLabel()
        end
    }

    return {
        Set = function(values)
            selectedMap = {}
            for _, v in ipairs(values or {}) do
                selectedMap[tostring(v)] = true
            end
            rebuildOptions(options)
            updateLabel()
        end,
        Get = function()
            return getSelectedList()
        end,
        Flag = flag,
        Refresh = function(newOptions)
            options = newOptions or options
            rebuildOptions(options)
            updateLabel()
        end,
    }
end

function RuneUI:CreateSlider(parent, title, min, max, default, callback, flag)
    flag = flag or title
    min = min or 0
    max = max or 100
    local value = default or min

    local holder = Create("Frame", {
        Parent = parent,
        Size = UDim2.new(1, 0, 0, 54),
        BackgroundTransparency = 1,
    })

    local label = Create("TextLabel", {
        Parent = holder,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -50, 0, 16),
        Font = Enum.Font.Code,
        Text = title,
        TextColor3 = Theme.Text,
        TextSize = 15,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local valueLabel = Create("TextLabel", {
        Parent = holder,
        BackgroundTransparency = 1,
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, 0, 0, 0),
        Size = UDim2.new(0, 50, 0, 16),
        Font = Enum.Font.Code,
        Text = tostring(value),
        TextColor3 = Theme.SubText,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Right,
    })

    local bar = Create("Frame", {
        Parent = holder,
        Position = UDim2.new(0, 0, 0, 28),
        Size = UDim2.new(1, 0, 0, 6),
        BackgroundColor3 = Theme.Surface2,
        BorderSizePixel = 0,
    })
    Round(bar, 999)
    local barStroke = Stroke(bar, Theme.BorderSoft)

    local fill = Create("Frame", {
        Parent = bar,
        Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
    })
    Round(fill, 999)

    local knob = Create("Frame", {
        Parent = bar,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new((value - min) / (max - min), 0, 0.5, 0),
        Size = UDim2.new(0, 12, 0, 12),
        BackgroundColor3 = Color3.fromRGB(245, 245, 246),
        BorderSizePixel = 0,
    })
    Round(knob, 999)

    local dragging = false

    local function setValue(v)
        v = math.clamp(tonumber(v) or min, min, max)
        value = v
        local pct = (value - min) / (max - min)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        knob.Position = UDim2.new(pct, 0, 0.5, 0)
        valueLabel.Text = tostring(value)
        Flags[flag] = value
        if callback then
            callback(value)
        end
    end

    local function setFromX(x)
        local pct = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
        local v = math.floor((min + (max - min) * pct) + 0.5)
        setValue(v)
    end

    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            setFromX(input.Position.X)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            setFromX(input.Position.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    Flags[flag] = value
    self:RegisterThemeObject(label, {TextColor3 = "Text"})
    self:RegisterThemeObject(valueLabel, {TextColor3 = "SubText"})
    self:RegisterThemeObject(bar, {BackgroundColor3 = "Surface2"})
    self:RegisterThemeObject(barStroke, {Color = "BorderSoft"})
    self:RegisterThemeObject(fill, {BackgroundColor3 = "Accent"})
    self.FlagObjects[flag] = {Type = "Slider", Set = setValue}

    return {
        Set = setValue,
        Get = function() return value end,
        Flag = flag,
    }
end

