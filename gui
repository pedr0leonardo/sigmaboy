local function cacheTransparency()
    savedTransparency = {}

    local function save(obj)
        savedTransparency[obj] = {}

        if obj:IsA("Frame") or obj:IsA("ScrollingFrame") or obj:IsA("TextButton") or obj:IsA("TextBox") or obj:IsA("ImageButton") or obj:IsA("ImageLabel") then
            savedTransparency[obj].BackgroundTransparency = obj.BackgroundTransparency
        end
        if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
            savedTransparency[obj].TextTransparency = obj.TextTransparency
        end
        if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
            savedTransparency[obj].ImageTransparency = obj.ImageTransparency
        end
        if obj:IsA("UIStroke") then
            savedTransparency[obj].Transparency = obj.Transparency
        end
    end

    save(mainUi)
    for _, obj in ipairs(mainUi:GetDescendants()) do
        save(obj)
    end
end

