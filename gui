local function Create(className, props)
    local obj = Instance.new(className)
    for k, v in pairs(props or {}) do
        obj[k] = v
    end
    return obj
end

local function Round(obj, radius)
    Create("UICorner", {
        CornerRadius = UDim.new(0, radius or 8),
        Parent = obj,
    })
end

local function Stroke(obj, color, thickness, transparency)
    local st = Create("UIStroke", {
        Color = color or Theme.Border,
        Thickness = thickness or 1,
        Transparency = transparency or 0,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
        LineJoinMode = Enum.LineJoinMode.Round,
        Parent = obj,
    })
    return st
end

local function Padding(obj, l, r, t, b)
    Create("UIPadding", {
        PaddingLeft = UDim.new(0, l or 0),
        PaddingRight = UDim.new(0, r or l or 0),
        PaddingTop = UDim.new(0, t or 0),
        PaddingBottom = UDim.new(0, b or t or 0),
        Parent = obj,
    })
end

local function ListLayout(obj, pad, horizontal, sort)
    return Create("UIListLayout", {
        Padding = UDim.new(0, pad or 0),
        FillDirection = horizontal and Enum.FillDirection.Horizontal or Enum.FillDirection.Vertical,
        SortOrder = sort or Enum.SortOrder.LayoutOrder,
        Parent = obj,
    })
end

local function AddHover(frame, goalIn, goalOut)
    local inTween = TweenService:Create(frame, TweenInfo.new(0.12), goalIn)
    local outTween = TweenService:Create(frame, TweenInfo.new(0.12), goalOut)
    frame.MouseEnter:Connect(function()
        inTween:Play()
    end)
    frame.MouseLeave:Connect(function()
        outTween:Play()
    end)
end

local function MakeDraggable(handle, target)
    local dragging = false
    local dragStart, startPos

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = target.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            target.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

function RuneUI:RegisterThemeObject(object, properties)
    table.insert(self.ThemeObjects, {
        Object = object,
        Properties = properties,
    })
end

function RuneUI:ApplyTheme(presetName)
    local preset = ThemePresets[presetName]
    if not preset then
        return false
    end

    for k, v in pairs(preset) do
        Theme[k] = v
    end
    Flags["Theme Preset"] = presetName

    for _, item in ipairs(self.ThemeObjects) do
        if item.Object and item.Object.Parent then
            for prop, themeKey in pairs(item.Properties) do
                local themeValue = Theme[themeKey]
                if themeValue ~= nil then
                    pcall(function()
                        item.Object[prop] = themeValue
                    end)
                end
            end
        end
    end

    for flag, obj in pairs(self.FlagObjects) do
        if obj and obj.Type == "Toggle" and obj.Set then
            obj.Set(Flags[flag] == true)
        end
    end

    for _, page in ipairs(self.Pages or {}) do
        if page.TabBoxes then
            for _, tabBox in ipairs(page.TabBoxes) do
                for _, tab in ipairs(tabBox.Tabs or {}) do
                    if tab.Content and tab.Content.Visible and tab.Select then
                        tab.Select()
                        break
                    end
                end
            end
        end
    end

    return true
end

function RuneUI:Notify(title, text, duration)
    duration = duration or 3

    local holder = self.NotificationHolder
    local card = Create("Frame", {
        Parent = holder,
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = Theme.Surface,
        BorderSizePixel = 0,
    })
    Round(card, 10)
    local cardStroke = Stroke(card, Theme.Border)
    Padding(card, 12, 12, 10, 10)

    local titleObj = Create("TextLabel", {
        Parent = card,
        Position = UDim2.new(0, 16, 0, 0),
        Size = UDim2.new(1, -20, 0, 18),
        BackgroundTransparency = 1,
        Font = Enum.Font.Code,
        Text = title,
        TextColor3 = Theme.Text,
        TextSize = 16,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local descObj = Create("TextLabel", {
        Parent = card,
        Position = UDim2.new(0, 16, 0, 22),
        Size = UDim2.new(1, -20, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Font = Enum.Font.Code,
        Text = text,
        TextWrapped = true,
        TextColor3 = Theme.SubText,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
    })

    local accent = Create("Frame", {
        Parent = card,
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 2, 1, -8),
        Position = UDim2.new(0, 0, 0, 4),
    })
    Round(accent, 2)

    self:RegisterThemeObject(card, {BackgroundColor3 = "Surface"})
    self:RegisterThemeObject(cardStroke, {Color = "Border"})
    self:RegisterThemeObject(titleObj, {TextColor3 = "Text"})
    self:RegisterThemeObject(descObj, {TextColor3 = "SubText"})
    self:RegisterThemeObject(accent, {BackgroundColor3 = "Accent"})

    card.BackgroundTransparency = 1
    card.Position = UDim2.new(1, 20, 0, 0)
    TweenService:Create(card, TweenInfo.new(0.18), {
        BackgroundTransparency = 0,
        Position = UDim2.new(0, 0, 0, 0),
    }):Play()

    task.delay(duration, function()
        local tween = TweenService:Create(card, TweenInfo.new(0.18), {
            BackgroundTransparency = 1,
            Position = UDim2.new(1, 20, 0, 0),
        })
        tween:Play()
        tween.Completed:Wait()
        if card then
            card:Destroy()
        end
    end)
end

function RuneUI:CreateToggle(parent, title, default, callback, flag)
    flag = flag or title
    local state = default == true

    local row = Create("Frame", {
        Parent = parent,
        Size = UDim2.new(1, 0, 0, 26),
        BackgroundTransparency = 1,
    })

    local label = Create("TextLabel", {
        Parent = row,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -60, 1, 0),
        Font = Enum.Font.Code,
        Text = title,
        TextColor3 = Theme.Text,
        TextSize = 15,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local toggleBtn = Create("TextButton", {
        Parent = row,
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.new(0, 42, 0, 22),
        BackgroundColor3 = state and Theme.Accent or Theme.Surface2,
        BorderSizePixel = 0,
        Text = "",
        AutoButtonColor = false,
    })
    Round(toggleBtn, 999)
    local toggleStroke = Stroke(toggleBtn, state and Theme.Accent or Theme.BorderSoft)

    local knob = Create("Frame", {
        Parent = toggleBtn,
        AnchorPoint = Vector2.new(0, 0.5),
        Position = state and UDim2.new(1, -20, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
        Size = UDim2.new(0, 18, 0, 18),
        BackgroundColor3 = Color3.fromRGB(245, 245, 246),
        BorderSizePixel = 0,
    })
    Round(knob, 999)

    local function setState(v)
        state = v == true
        Flags[flag] = state
        TweenService:Create(toggleBtn, TweenInfo.new(0.15), {
            BackgroundColor3 = state and Theme.Accent or Theme.Surface2,
        }):Play()
        TweenService:Create(toggleStroke, TweenInfo.new(0.15), {
            Color = state and Theme.Accent or Theme.BorderSoft,
        }):Play()
        TweenService:Create(knob, TweenInfo.new(0.15), {
            Position = state and UDim2.new(1, -20, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
        }):Play()
        if callback then
            callback(state)
        end
    end

    toggleBtn.MouseButton1Click:Connect(function()
        setState(not state)
    end)

    Flags[flag] = state
    self:RegisterThemeObject(label, {TextColor3 = "Text"})
    self.FlagObjects[flag] = {Type = "Toggle", Set = setState, Stroke = toggleStroke, Button = toggleBtn}

    return {
        Set = setState,
        Get = function() return state end,
        Flag = flag,
    }
end

function RuneUI:CreateButton(parent, title, callback)
    local btn = Create("TextButton", {
        Parent = parent,
        Size = UDim2.new(1, 0, 0, 32),
        BackgroundColor3 = Theme.Surface2,
        BorderSizePixel = 0,
        Text = title,
        Font = Enum.Font.Code,
        TextColor3 = Theme.Text,
        TextSize = 15,
        AutoButtonColor = false,
    })
    Round(btn, 8)
    local st = Stroke(btn, Theme.Border)
    AddHover(btn, {BackgroundColor3 = Color3.fromRGB(30, 30, 36)}, {BackgroundColor3 = Theme.Surface2})
    self:RegisterThemeObject(btn, {BackgroundColor3 = "Surface2", TextColor3 = "Text"})
    self:RegisterThemeObject(st, {Color = "Border"})
    btn.MouseButton1Click:Connect(function()
        if callback then
            callback()
        end
    end)
    return btn
end

function RuneUI:CreateTextbox(parent, title, placeholder, callback, flag)
    flag = flag or title

    local holder = Create("Frame", {
        Parent = parent,
        Size = UDim2.new(1, 0, 0, 56),
        BackgroundTransparency = 1,
    })

    local label = Create("TextLabel", {
        Parent = holder,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 16),
        Font = Enum.Font.Code,
        Text = title,
        TextColor3 = Theme.Text,
        TextSize = 15,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local box = Create("TextBox", {
        Parent = holder,
        Position = UDim2.new(0, 0, 0, 22),
        Size = UDim2.new(1, 0, 0, 30),
        BackgroundColor3 = Theme.Surface2,
        BorderSizePixel = 0,
        PlaceholderText = placeholder or "",
        Font = Enum.Font.Code,
        Text = "",
        TextColor3 = Theme.Text,
        PlaceholderColor3 = Theme.Placeholder,
        TextSize = 15,
        ClearTextOnFocus = false,
    })
    Round(box, 8)
    local st = Stroke(box, Theme.Border)

    box:GetPropertyChangedSignal("Text"):Connect(function()
        Flags[flag] = box.Text
    end)

    local function setText(v)
        box.Text = tostring(v or "")
        Flags[flag] = box.Text
    end

    box.FocusLost:Connect(function()
        Flags[flag] = box.Text
        if callback then
            callback(box.Text)
        end
    end)

    Flags[flag] = box.Text
    self:RegisterThemeObject(label, {TextColor3 = "Text"})
    self:RegisterThemeObject(box, {BackgroundColor3 = "Surface2", TextColor3 = "Text", PlaceholderColor3 = "Placeholder"})
    self:RegisterThemeObject(st, {Color = "Border"})
    self.FlagObjects[flag] = {Type = "Textbox", Set = setText}

    return {
        Set = setText,
        Get = function() return box.Text end,
        Flag = flag,
        Object = box,
    }
end

