        UDim2.new(startPos.X.Scale, startPos.X.Offset + 2, startPos.Y.Scale, startPos.Y.Offset),
        startPos
    }

    local iconRots = {-10, 10, -6, 6, 0}

    task.spawn(function()
        for i = 1, #shakeOffsets do
            TweenService:Create(toggleCircle, TweenInfo.new(0.035, Enum.EasingStyle.Linear), {
