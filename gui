    self:RegisterThemeObject(pageButton, {BackgroundColor3 = "Background2"})
    self:RegisterThemeObject(pageStroke, {Color = "BorderSoft"})
    self:RegisterThemeObject(pageIcon, {ImageColor3 = "SubText"})

    pageButton.MouseButton1Click:Connect(function()
        self:OpenPage(pageData)
    end)

    table.insert(self.Pages, pageData)
    if #self.Pages == 1 then
        self:OpenPage(pageData)
    end

    return pageData
end

function RuneUI:OpenPage(pageData)
    if self.OpenDropdowns then
        for _, close in ipairs(self.OpenDropdowns) do
            close()
        end
    end

    for _, pg in ipairs(self.Pages) do
        pg.Frame.Visible = false
        TweenService:Create(pg.Button, TweenInfo.new(0.12), {
            BackgroundColor3 = Theme.Background2
        }):Play()
        TweenService:Create(pg.Icon, TweenInfo.new(0.12), {
            ImageColor3 = Theme.SubText
        }):Play()
    end

    pageData.Frame.Visible = true
    TweenService:Create(pageData.Button, TweenInfo.new(0.12), {
        BackgroundColor3 = Theme.Surface
    }):Play()
    TweenService:Create(pageData.Icon, TweenInfo.new(0.12), {
        ImageColor3 = Theme.Accent
    }):Play()

    self.CurrentPage = pageData
end

function RuneUI:RegisterSearchEntry(name, pageData, tabIndex, aliases)
    local entry = {
        Name = tostring(name),
        Lower = string.lower(tostring(name)),
        Page = pageData,
        TabIndex = tabIndex,
        Aliases = {},
    }

    for _, alias in ipairs(aliases or {}) do
        table.insert(entry.Aliases, string.lower(tostring(alias)))
    end

    table.insert(self.SearchEntries, entry)
end

function RuneUI:SetSearchResultsVisible(isVisible)
    if not self.SearchResultsFrame then
        return
    end

    self.SearchResultsFrame.Visible = isVisible == true
end

function RuneUI:ShowSearchResults(matches)
    for _, child in ipairs(self.SearchResultsList:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end

    if not matches or #matches == 0 then
        self:SetSearchResultsVisible(false)
        return
    end

    self:SetSearchResultsVisible(true)

    for i, entry in ipairs(matches) do
        if i > 8 then
            break
        end

        local button = Create("TextButton", {
            Parent = self.SearchResultsList,
            Size = UDim2.new(1, 0, 0, 28),
            BackgroundColor3 = Theme.Surface2,
            BorderSizePixel = 0,
            Text = entry.Name,
            Font = Enum.Font.Code,
            TextColor3 = Theme.Text,
            TextSize = 14,
            AutoButtonColor = false,
            ZIndex = 52,
        })
        Round(button, 6)
        local st = Stroke(button, Theme.BorderSoft)
        AddHover(button, {BackgroundColor3 = Theme.Surface}, {BackgroundColor3 = Theme.Surface2})
        self:RegisterThemeObject(button, {BackgroundColor3 = "Surface2", TextColor3 = "Text"})
        self:RegisterThemeObject(st, {Color = "BorderSoft"})

        button.MouseButton1Click:Connect(function()
            self.SearchBox.Text = entry.Name
            self:SetSearchResultsVisible(false)

            if entry.Page then
                self:OpenPage(entry.Page)
            end

            if entry.TabIndex and entry.Page and entry.Page.TabBoxes then
                for _, tabBox in ipairs(entry.Page.TabBoxes) do
                    local tab = tabBox.Tabs[entry.TabIndex]
                    if tab and tab.Select then
                        if self.OpenDropdowns then
                            for _, close in ipairs(self.OpenDropdowns) do
                                close()
                            end
                        end
                        tab.Select()
                        break
                    end
                end
            end

            self:Notify("Search", "Jumped to: " .. entry.Name, 2)
        end)
    end
end

function RuneUI:RunSearch(query)
    query = string.lower(tostring(query or ""))
    query = query:gsub("^%s+", ""):gsub("%s+$", "")

    if query == "" then
        self:ShowSearchResults({})
        return nil
    end

    local matches = {}

    for _, entry in ipairs(self.SearchEntries) do
        local matched = string.find(entry.Lower, query, 1, true) ~= nil
        if not matched then
            for _, alias in ipairs(entry.Aliases or {}) do
                if string.find(alias, query, 1, true) then
                    matched = true
                    break
                end
            end
        end
        if matched then
            table.insert(matches, entry)
        end
    end

    self:ShowSearchResults(matches)

    if #matches == 0 then
        return nil
    end

    return matches
end

